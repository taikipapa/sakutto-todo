{
  "expo": {
    "name": "サクッとTodo",
    "slug": "TodoApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.taikipapa.sakuttotodo",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2833241675946579~2258971013",
          "iosAppId": "ca-app-pub-2833241675946579~1684255941"
        }
      ],
      "expo-font",
      "expo-notifications",
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "広告を最適化するために、トラッキングの許可をお願いします。"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "241a4554-da99-4ee4-9bb7-40d308fe41d9"
      }
    },
    "owner": "daitaina"
  }
}
